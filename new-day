#!/usr/bin/env python3
"""Scaffold a new Advent of Code day and download input + example via aocd.

Usage:
  ./new-day 1        -> creates day01/
  ./new-day 25       -> creates day25/

Creates:
  dayNN/solution.chatter   starter program
  dayNN/example.txt        sample input (auto-fetched, may need a sanity check)
  dayNN/input.txt          your personal puzzle input (git-ignored)

Requires `advent-of-code-data` (aocd). Install with:
  pip install advent-of-code-data

Configure your session token once via either:
  - ~/.config/aocd/token  (single token file), or
  - the AOC_SESSION env var.

Refuses to overwrite an existing dayNN/ directory.
"""

from __future__ import annotations

import os
import re
import sys
from pathlib import Path

YEAR = 2025

REPO_ROOT = Path(__file__).resolve().parent


SOLUTION_TEMPLATE = """# Advent of Code {year} — Day {day}
# Run: ./chatter {dir}/solution.chatter 

function part1 takes string path returns number is
  return 0
end function

function part2 takes string path returns number is
  return 0
end function

say "Day {day}:"
part1 "example.txt"
say "part 1 example:", it
expect it is 0
part1 "input.txt"
say "part 1 input:", it
expect it is 0

part2 "example.txt"
say "part 2 example:", it
expect it is 0
part2 "input.txt"
say "part 2 input:", it
expect it is 0
"""


def die(msg: str, code: int = 1) -> "None":
    print(f"new-day: {msg}", file=sys.stderr)
    sys.exit(code)


def parse_day(argv: list[str]) -> int:
    if len(argv) != 2:
        die(f"usage: {argv[0]} <day-number>", 2)
    raw = argv[1]
    if not re.fullmatch(r"[0-9]+", raw):
        die(f"day must be an integer 1..25 (got '{raw}')", 2)
    day = int(raw)
    if not 1 <= day <= 25:
        die(f"day must be an integer 1..25 (got '{raw}')", 2)
    return day


def ensure_aocd():
    try:
        from aocd.models import Puzzle  # noqa: F401
    except ImportError:
        die(
            "advent-of-code-data not installed. Install with:\n"
            "    pip install advent-of-code-data",
            3,
        )
    if "AOC_SESSION" not in os.environ:
        token_file = Path.home() / ".config" / "aocd" / "token"
        if not token_file.exists():
            die(
                "no AoC session token found. Set AOC_SESSION env var or write "
                f"your session cookie to {token_file}",
                3,
            )


def fetch_input(day: int) -> str:
    from aocd.models import Puzzle

    puzzle = Puzzle(year=YEAR, day=day)
    return puzzle.input_data + "\n"


def fetch_example(day: int) -> str | None:
    """Best-effort example fetch via aocd's example parser.

    Returns the example text (with trailing newline) or None if no example
    could be extracted (e.g. puzzle not yet unlocked, or parser found none).
    """
    from aocd.models import Puzzle

    try:
        puzzle = Puzzle(year=YEAR, day=day)
        examples = puzzle.examples
    except Exception as exc:  # noqa: BLE001
        print(f"new-day: could not fetch examples ({exc})", file=sys.stderr)
        return None
    if not examples:
        return None
    return examples[0].input_data + "\n"


def update_gitignore(rule: str) -> None:
    gitignore = REPO_ROOT / ".gitignore"
    existing = gitignore.read_text().splitlines() if gitignore.exists() else []
    if rule in existing:
        return
    with gitignore.open("a") as fh:
        fh.write(rule + "\n")
    print(f"new-day: added '{rule}' to .gitignore")


def main() -> None:
    day = parse_day(sys.argv)
    dir_name = f"day{day:02d}"
    target = REPO_ROOT / dir_name

    if target.exists():
        die(f"{dir_name}/ already exists — refusing to overwrite", 1)

    ensure_aocd()

    target.mkdir(parents=True)

    (target / "solution.chatter").write_text(
        SOLUTION_TEMPLATE.format(year=YEAR, day=day, dir=dir_name)
    )

    # Fetch input (required — error out if it fails so the user notices).
    try:
        input_text = fetch_input(day)
    except Exception as exc:  # noqa: BLE001
        # Clean up the half-scaffolded directory so re-running is painless.
        (target / "solution.chatter").unlink(missing_ok=True)
        target.rmdir()
        die(f"failed to download input for day {day}: {exc}", 4)
    (target / "input.txt").write_text(input_text)
    print(f"new-day: downloaded input.txt ({len(input_text)} bytes)")

    example_text = fetch_example(day)
    if example_text is None:
        (target / "example.txt").write_text("")
        print(
            "new-day: no example auto-detected — paste it into example.txt",
            file=sys.stderr,
        )
    else:
        (target / "example.txt").write_text(example_text)
        print(f"new-day: downloaded example.txt ({len(example_text)} bytes) — sanity-check it")

    rule = f"{dir_name}/input.txt"
    update_gitignore(rule)

    print(f"new-day: scaffolded {dir_name}/")
    for entry in sorted(target.iterdir()):
        print(f"  {entry.name}")


if __name__ == "__main__":
    main()
